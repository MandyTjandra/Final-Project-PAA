STRUCTURE Endpoint
    type, idx, id, r, c, dir
END STRUCTURE

STRUCTURE State
    dist, r, c, dir
END STRUCTURE

STRUCTURE ParentInfo
    r, c, dir, mirror
END STRUCTURE

READ x, y
IF input fails THEN
    EXIT
END IF

CREATE LIST top_arr OF SIZE y
CREATE LIST bottom_arr OF SIZE y
CREATE LIST left_arr OF SIZE x
CREATE LIST right_arr OF SIZE x

FOR i FROM 0 TO y - 1
    READ top_arr[i]
END FOR

FOR i FROM 0 TO x - 1
    READ left_arr[i]
    READ right_arr[i]
END FOR

FOR i FROM 0 TO y - 1
    READ bottom_arr[i]
END FOR

CREATE 2D ARRAY grid OF SIZE x BY y
FOR r FROM 0 TO x - 1
    FOR c FROM 0 TO y - 1
        grid[r][c] = '.'
    END FOR
END FOR

CREATE LIST perim
FOR i FROM 0 TO y - 1
    APPEND Endpoint(0, i, top_arr[i], 0, i, 2) TO perim
END FOR
FOR i FROM 0 TO x - 1
    APPEND Endpoint(1, i, right_arr[i], i, y - 1, 3) TO perim
END FOR
FOR i FROM y - 1 DOWN TO 0
    APPEND Endpoint(2, i, bottom_arr[i], x - 1, i, 0) TO perim
END FOR
FOR i FROM x - 1 DOWN TO 0
    APPEND Endpoint(3, i, left_arr[i], i, 0, 1) TO perim
END FOR

CREATE LIST pairs_to_route
CREATE STACK s

FOR EACH ep IN perim
    IF s IS NOT EMPTY AND s.top().id == ep.id THEN
        APPEND (s.top(), ep) TO pairs_to_route
        s.pop()
    ELSE
        s.push(ep)
    END IF
END FOR

IF s IS NOT EMPTY THEN
    PRINT -1
    EXIT
END IF

FOR EACH p IN pairs_to_route
    start_ep = p.first
    target_ep = p.second

    INITIALIZE 3D ARRAY dist WITH INFINITY
    CREATE MIN_PRIORITY_QUEUE pq

    pq.push(State(0, start_ep.r, start_ep.c, start_ep.dir))
    dist[start_ep.r][start_ep.c][start_ep.dir] = 0

    found = FALSE

    WHILE pq IS NOT EMPTY
        curr = pq.top()
        pq.pop()

        IF curr.dist > dist[curr.r][curr.c][curr.dir] THEN
            CONTINUE
        END IF

        r = curr.r
        c = curr.c
        dir = curr.dir

        CREATE ARRAY possible_mirrors OF SIZE 2
        num_m = 0

        IF grid[r][c] == '.' THEN
            possible_mirrors[0] = '/'
            possible_mirrors[1] = '\'
            num_m = 2
        ELSE
            possible_mirrors[0] = grid[r][c]
            num_m = 1
        END IF

        FOR i FROM 0 TO num_m - 1
            m = possible_mirrors[i]
            ndir = -1

            IF m == '\' THEN
                next_dir = [3, 2, 1, 0]
                ndir = next_dir[dir]
            ELSE
                next_dir = [1, 0, 3, 2]
                ndir = next_dir[dir]
            END IF

            nr = r
            nc = c
            IF ndir == 0 THEN
                nr = nr - 1
            ELSE IF ndir == 1 THEN
                nc = nc + 1
            ELSE IF ndir == 2 THEN
                nr = nr + 1
            ELSE IF ndir == 3 THEN
                nc = nc - 1
            END IF

            IF nr < 0 OR nr >= x OR nc < 0 OR nc >= y THEN
                is_target = FALSE
                IF nr < 0 AND target_ep.type == 0 AND target_ep.idx == nc THEN
                    is_target = TRUE
                ELSE IF nr >= x AND target_ep.type == 2 AND target_ep.idx == nc THEN
                    is_target = TRUE
                ELSE IF nc < 0 AND target_ep.type == 3 AND target_ep.idx == nr THEN
                    is_target = TRUE
                ELSE IF nc >= y AND target_ep.type == 1 AND target_ep.idx == nr THEN
                    is_target = TRUE
                END IF

                IF is_target == TRUE THEN
                    br = r
                    bc = c
                    bdir = dir
                    bm = m
                    
                    WHILE TRUE
                        IF grid[br][bc] == '.' THEN
                            grid[br][bc] = bm
                        END IF
                        
                        IF br == start_ep.r AND bc == start_ep.c AND bdir == start_ep.dir THEN
                            BREAK
                        END IF
                        
                        pi = parent_info[br][bc][bdir]
                        br = pi.r
                        bc = pi.c
                        bdir = pi.dir
                        bm = pi.mirror
                    END WHILE
                    
                    found = TRUE
                    BREAK
                END IF
            ELSE
                weight = 0
                IF grid[nr][nc] == '.' THEN
                    IF m == '/' THEN
                        weight = 10
                    ELSE
                        weight = 11
                    END IF
                END IF

                IF dist[r][c][dir] + weight < dist[nr][nc][ndir] THEN
                    dist[nr][nc][ndir] = dist[r][c][dir] + weight
                    parent_info[nr][nc][ndir] = ParentInfo(r, c, dir, m)
                    pq.push(State(dist[nr][nc][ndir], nr, nc, ndir))
                END IF
            END IF
        END FOR

        IF found == TRUE THEN
            BREAK
        END IF
    END WHILE

    IF found == FALSE THEN
        PRINT -1
        EXIT
    END IF
END FOR

FOR r FROM 0 TO x - 1
    FOR c FROM 0 TO y - 1
        IF grid[r][c] == '.' THEN
            grid[r][c] = '/'
        END IF
        PRINT grid[r][c] WITHOUT NEWLINE
    END FOR
    PRINT NEWLINE
END FOR
